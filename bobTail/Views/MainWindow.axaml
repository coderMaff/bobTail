<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:bobTail.ViewModels"
        xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="bobTail.Views.MainWindow"
        Background="HotPink">

    <Window.Styles>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <Style Selector="ListBox TextBlock">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- Unread tab text -->
        <Style Selector="TabControl TextBlock.unread">
            <Setter Property="Foreground" Value="Lime" />
        </Style>

        <!-- Tail toggle visual -->
        <Style Selector="ToggleButton.tailOn">
            <Setter Property="Background" Value="LimeGreen" />
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <!-- Tighter tab header padding -->
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="4,2" />
        </Style>

    </Window.Styles>

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True" Margin="10">

        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Spacing="10">
            <Button Content="Open File"
                    Width="120"
                    Click="OpenFileButton_OnClick" />

            <Button Content="Settings"
                    Width="120"
                    Click="SettingsButton_OnClick" />
        </StackPanel>

        <TabControl ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}">

            <TabControl.ItemTemplate>
                <DataTemplate DataType="vm:LogTabViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="6">

                        <material:MaterialIcon Kind="{Binding IconKind, FallbackValue=FileDocumentOutline}"
                                               Width="16" Height="16" />

                        <TextBlock Text="{Binding Title}"
                                   Classes.unread="{Binding HasUnread}" />

                        <ToggleButton IsChecked="{Binding AutoScroll}"
                                      Classes.tailOn="{Binding AutoScroll}"
                                      Width="18"
                                      Height="18"
                                      Margin="4,0,0,0"
                                      ToolTip.Tip="Tail (auto-scroll)">
                            <material:MaterialIcon Kind="ArrowDownBold"
                                                   Width="14"
                                                   Height="14" />
                        </ToggleButton>

                        <Button Content="×"
                                Margin="6,0,0,0"
                                Padding="0"
                                Width="18"
                                Height="18"
                                Click="CloseTab_OnClick"
                                CommandParameter="{Binding}" />
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate DataType="vm:LogTabViewModel">
                    <ListBox ItemsSource="{Binding Lines}"
                             FontFamily="Consolas"
                             Background="DeepSkyBlue"
                             ScrollViewer.ScrollChanged="LogList_OnScrollChanged" />
                </DataTemplate>
            </TabControl.ContentTemplate>

        </TabControl>

    </DockPanel>
</Window>
