<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:bobTail.ViewModels"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia" x:Class="bobTail.Views.MainWindow" Background="HotPink">

    <Window.Styles>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <Style Selector="ListBox TextBlock">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="ListBoxItem:nth-child(4) TextBlock">
            <Setter Property="Foreground" Value="Orange" />
        </Style>

        <!-- Unread tab text -->
        <Style Selector="TabControl TextBlock.unread">
            <Setter Property="Foreground" Value="Lime" />
        </Style>

        <!-- Tighter tab header padding -->
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="4,2" />
        </Style>

    </Window.Styles>

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True" Margin="10">

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10">
            <Button Content="Open File" Width="120" Click="OpenFileButton_OnClick" />

            <Button Content="Settings" Width="120" Click="SettingsButton_OnClick" />

            <Button Content="About" Width="120" Click="AboutButton_OnClick" />

            <Separator />

            <Button Content="Top" Width="120" Click="TopButton_OnClick" />

            <Button Content="Bottom" Width="120" Click="BottomButton_OnClick" />
        </StackPanel>

        <TabControl ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}" x:Name="TabControl">

            <TabControl.ItemTemplate>
                <DataTemplate DataType="vm:LogTabViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="6">

                        <material:MaterialIcon Kind="{Binding IconKind, FallbackValue=FileDocumentOutline}" Width="16" Height="16" />

                        <TextBlock Text="{Binding Title}" Classes.unread="{Binding HasUnread}" />

                        <ToggleButton x:Name="TailToggle" IsChecked="{Binding AutoScroll}" Width="18" Height="30" Margin="6,0,0,0" ToolTip.Tip="Tail (auto-scroll)" Background="black"/>

                        <Button Content="×" Margin="6,0,0,0" Padding="0" Width="18" Height="30" Click="CloseTab_OnClick" CommandParameter="{Binding}" Background="red" />
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate DataType="vm:LogTabViewModel">
                    <ListBox ItemsSource="{Binding Lines}" FontFamily="Consolas" Background="DeepSkyBlue" ScrollViewer.ScrollChanged="LogList_OnScrollChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text, Mode=OneWay}" Foreground="{Binding Foreground, Mode=OneWay}" Background="{Binding Background, Mode=OneWay}" FontFamily="Consolas" Padding="0" Height="18"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DataTemplate>
            </TabControl.ContentTemplate>

        </TabControl>

    </DockPanel>
</Window>
