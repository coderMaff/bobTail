<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:bobTail.ViewModels"
        xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia" x:Class="bobTail.Views.MainWindow" Background="#222222" Title="bobTail logfile viewer (c)2026 Matt Bushell">

    <Window.Styles>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <Style Selector="ListBox TextBlock">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="ListBoxItem:nth-child(4) TextBlock">
            <Setter Property="Foreground" Value="Orange" />
        </Style>

        <!-- Unread tab text -->
        <Style Selector="TabControl TextBlock.unread">
            <Setter Property="Foreground" Value="Lime" />
        </Style>

        <!-- Tighter tab header padding -->
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="4,2" />
        </Style>

    </Window.Styles>

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel LastChildFill="True" Margin="10">

        <Grid DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Row 0 -->
            <Button Grid.Row="0" Grid.Column="0" Content="Open File" Width="120" Click="OpenFileButton_OnClick"/>
            <Button Grid.Row="0" Grid.Column="1" Content="About" Width="120" Click="AboutButton_OnClick"/>
            <Separator Grid.Row="0" Grid.Column="2" Width="20"/>
            <Button Grid.Row="0" Grid.Column="3" Content="Top" Width="120" Click="TopButton_OnClick"/>
            <Separator Grid.Row="0" Grid.Column="4" Width="20"/>
            <Button Grid.Row="0" Grid.Column="5" Content="Find Next" Width="120" Click="FindNextButton_OnClick"/>
            <Button Grid.Row="0" Grid.Column="6" Content="Find Prev" Width="120" Click="FindPrevButton_OnClick"/>
            <TextBox Grid.Row="0" Grid.Column="7" Text="{Binding FindText}" Watermark="Search..." Width="300"/>

            <!-- Row 1 (every second element) -->
    
            <Button Grid.Row="1" Grid.Column="0" Content="Settings" Width="120" Click="SettingsButton_OnClick"/>
            <Separator Grid.Row="1" Grid.Column="2" Width="20"/>
            <Button Grid.Row="1" Grid.Column="3" Content="Bottom" Width="120" Click="BottomButton_OnClick"/>
            <Separator Grid.Row="1" Grid.Column="4" Width="20"/>
            <Button Grid.Row="1" Grid.Column="6" Content="Filter" Width="120" Click="FilterButton_OnClick"/>
            <TextBox Grid.Row="1" Grid.Column="7" Text="{Binding FilterText}" Watermark="Filter..." Width="300"/>
        </Grid>


        <TabControl ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}" x:Name="TabControl">

            <TabControl.ItemTemplate>
                <DataTemplate DataType="vm:LogTabViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="6" Background="#444444">

                        <material:MaterialIcon Kind="{Binding IconKind, FallbackValue=FileDocumentOutline}" Width="16" Height="16" />

                        <TextBlock Text="{Binding Title}" Classes.unread="{Binding HasUnread}" />

                        <ToggleButton Content="T" x:Name="TailToggle" IsChecked="{Binding AutoScroll}" Width="18" Height="30" Margin="6,0,0,0" ToolTip.Tip="Tail (auto-scroll)" Background="black"/>

                        <Button Content="X" Margin="6,0,0,0" Padding="0" Width="18" Height="30" Click="CloseTab_OnClick" CommandParameter="{Binding}" Background="red" />
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate DataType="vm:LogTabViewModel">
                    <ListBox ItemsSource="{Binding Lines}" FontFamily="Consolas" Background="DeepSkyBlue" ScrollViewer.ScrollChanged="LogList_OnScrollChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text, Mode=OneWay}" Foreground="{Binding Foreground, Mode=OneWay}" Background="{Binding Background, Mode=OneWay}" FontFamily="Consolas" Padding="0" Height="18"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DataTemplate>
            </TabControl.ContentTemplate>

        </TabControl>

    </DockPanel>
</Window>
